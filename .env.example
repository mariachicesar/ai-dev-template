# {{PROJECT_NAME}} — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── GitHub MCP ──────────────────────────────────────────
GITHUB_TOKEN=                    # Personal access token (repo, read:org scopes)
GITHUB_REPO={{GITHUB_REPO}}      # e.g., your-org/your-repo

# ── Jira (Atlassian) MCP ───────────────────────────────
JIRA_BASE_URL=                   # e.g., https://your-org.atlassian.net
JIRA_EMAIL=                      # Your Atlassian account email
JIRA_API_TOKEN=                  # API token from https://id.atlassian.net/manage-profile/security/api-tokens
JIRA_PROJECT_KEY={{JIRA_KEY}}    # e.g., METH

# ── Vercel MCP ──────────────────────────────────────────
VERCEL_TOKEN=                    # From https://vercel.com/account/tokens
VERCEL_PROJECT_ID=               # From Vercel project settings
VERCEL_TEAM_ID=                  # (optional) From Vercel team settings

# ── Google Ads MCP (Read-Only) ──────────────────────────
GOOGLE_ADS_CLIENT_ID=            # OAuth2 client ID
GOOGLE_ADS_CLIENT_SECRET=        # OAuth2 client secret
GOOGLE_ADS_REFRESH_TOKEN=        # OAuth2 refresh token
GOOGLE_ADS_DEVELOPER_TOKEN=      # From Google Ads API Center
GOOGLE_ADS_CUSTOMER_ID=          # e.g., 123-456-7890 (no dashes)

# ── WordPress REST ──────────────────────────────────────
WP_BASE_URL=                     # e.g., https://cms.example.com
WP_APPLICATION_PASSWORD=         # From WP Admin → Users → Application Passwords
WP_USERNAME=                     # WordPress username for auth
